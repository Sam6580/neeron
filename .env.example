# ---- Database ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=neeron

# Backend connection strings (compose builds these automatically; override if needed)
# DATABASE_URL=postgresql+asyncpg://postgres:change-me@db:5432/neeron
# REDIS_URL=redis://redis:6379/0

# ---- Auth / security (REQUIRED in production) ----
# Generate a strong random value, e.g.  openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- CORS ----
# Comma-separated list of allowed browser origins for the API.
CORS_ORIGINS=http://localhost:3000

# ---- Messaging ----
MQTT_BROKER=mqtt
MQTT_PORT=1883
MQTT_ENABLED=true

# ---- Frontend ----
# Public base URL the browser uses to reach the API (inlined at build time).
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
